# ============================================================================
# house_marker.gd — 大本营（House）绘制脚本
# ============================================================================
# 对应场景：scenes/game/house_marker.tscn
# 参考 DESIGN.md 第 5.2 节
#
# 大本营结构（俯视角看下来的同心圆）：
#   - 12 英尺环（最外）= 约 183 cm → 按比例缩放为像素
#   - 8 英尺环
#   - 4 英尺环
#   - 1 英尺按钮（Button，中心点）
#
# 颜色方案（参考标准冰壶赛道）：
#   外环红 → 白 → 蓝 → 白（按钮）
# ============================================================================

extends Node2D

# ============================================================================
# 导出参数
# ============================================================================

## 最外环半径（像素）— 对应 12 英尺环
@export var outer_radius: float = 120.0

## 像素/英尺 比例（outer_radius / 6 英尺 = 半径对应的英尺数）
## 12 英尺环的半径 = 6 英尺 → scale = outer_radius / 6
@export var scale_factor: float = 20.0  # 每英尺 20 像素

# ============================================================================
# 环半径计算（英尺转像素）
# ============================================================================

## 获取各环的半径（像素值）
## 12英尺环半径 = 6英尺 × scale_factor = 120px
## 8英尺环半径 = 4英尺 × scale_factor = 80px
## 4英尺环半径 = 2英尺 × scale_factor = 40px
## 按钮半径 = 0.5英尺 × scale_factor = 10px
func _get_ring_radii() -> Array[float]:
	return [
		6.0 * scale_factor,   # 12 英尺环（最外）
		4.0 * scale_factor,   # 8 英尺环
		2.0 * scale_factor,   # 4 英尺环
		0.5 * scale_factor,   # 1 英尺按钮
	]

# ============================================================================
# 绘制
# ============================================================================

func _ready() -> void:
	# 触发一次重绘
	queue_redraw()


func _draw() -> void:
	var radii: Array[float] = _get_ring_radii()
	
	# 定义各环颜色（从外到内）
	var colors: Array[Color] = [
		Color(0.9, 0.2, 0.2, 0.7),   # 12英尺环 — 红色
		Color(1.0, 1.0, 1.0, 0.7),   # 8英尺环 — 白色
		Color(0.2, 0.3, 0.9, 0.7),   # 4英尺环 — 蓝色
		Color(1.0, 1.0, 1.0, 0.9),   # 按钮 — 白色
	]
	
	# 从外到内依次绘制填充圆（后绘制的会覆盖前面的）
	for i in range(radii.size()):
		draw_circle(Vector2.ZERO, radii[i], colors[i])
	
	# 绘制十字线（T线和中线在这里不画，由赛道绘制）
	# 只画大本营内的十字辅助线
	var cross_len: float = radii[0]  # 十字延伸到最外环
	var cross_color: Color = Color(0.3, 0.3, 0.3, 0.5)
	draw_line(Vector2(-cross_len, 0), Vector2(cross_len, 0), cross_color, 1.0)  # 水平
	draw_line(Vector2(0, -cross_len), Vector2(0, cross_len), cross_color, 1.0)  # 垂直
